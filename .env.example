# Copy to `.env` in this directory. Docker Compose loads `.env` automatically for ${VAR} substitution.
#
# When using ngrok (`ngrok http 4317`), paste the HTTPS forwarding URL here (no trailing slash).
# Free ngrok URLs change each time you restart ngrok unless you use a reserved domain.
#
TRITON_PUBLIC_RUNTIME_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev
